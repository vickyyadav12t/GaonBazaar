# Copy to .env.local (or .env) for local development.
# On Vercel: set VITE_API_BASE_URL in Project → Settings → Environment Variables (Production).

# API base URL (must match backend routes under /api)
VITE_API_BASE_URL=http://localhost:5000/api
# Production example: https://gaonbazaar.onrender.com/api

# Socket.IO server origin (same host as API without /api — your Farm-back server)
VITE_SOCKET_URL=http://localhost:5000

# Google OAuth Web client ID (same project as Farm-back GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=

# Landing page: `live` = show real counts from GET /api/public/landing-stats (omit for honest marketing copy)
# VITE_LANDING_STATS_MODE=live

# Vite sets BASE_URL automatically; only override if deploying under a subpath.
