# Copy to .env and fill in values.

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/gaonbazaar

# JWT signing secret — use a long random string in production (never commit .env)
JWT_SECRET=change-me-in-production

# Server port
PORT=5000

# Allowed browser origins (comma-separated). Must match the browser address exactly
# (localhost vs 127.0.0.1 are different origins). Include your Vite URL or Socket.IO will fail.
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

# Public URL of the frontend (password reset links, emails, etc.)
FRONTEND_URL=http://localhost:8080
# Optional alias used in some controllers
# CLIENT_URL=http://localhost:8080

# Google Sign-In (server verifies ID token — must match frontend VITE_GOOGLE_CLIENT_ID project)
GOOGLE_CLIENT_ID=

# Razorpay (server creates orders and verifies signatures)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email (optional — registration / password flows may require for production)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Branding in emails
APP_NAME=GaonBazaar

# Optional: throttle negotiation notification emails (ms)
# NEGOTIATION_EMAIL_COOLDOWN_MS=600000

# Behind nginx/Render/etc. set TRUST_PROXY=1 so rate limiting and IPs are correct
# TRUST_PROXY=1

# Public JSON (no auth): GET /api/public/landing-stats — farmer/buyer/delivered-order/active-listing counts for the SPA

# API rate limit (requests per IP per 15 min window). Set RATE_LIMIT_DISABLED=1 to turn off (dev only).
# RATE_LIMIT_MAX=400
# RATE_LIMIT_DISABLED=0

# Groq — Mandi-ready listing coach (server-side only; never expose in Vite)
# https://console.groq.com/keys
GROQ_API_KEY=
# Optional override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
# Copilot: Groq json_object mode (set 0 if API errors on response_format)
# GROQ_COPILOT_JSON_MODE=1
# Per-user cap for POST /api/ai/listing-coach (per hour)
# AI_LISTING_COACH_MAX_PER_HOUR=25
# Per-user cap for POST /api/ai/fair-deal-coach (per hour)
# AI_FAIR_DEAL_MAX_PER_HOUR=40
# Per user (if JWT) or per IP for POST /api/ai/help-chat (floating help bot, per hour)
# AI_HELP_CHAT_MAX_PER_HOUR=50
# Farmer-only hybrid news (curated links + Groq digest), per user per hour
# AI_FARMER_NEWS_MAX_PER_HOUR=24
# Unified AI Copilot (farmers + buyers), per user per hour
# AI_COPILOT_MAX_PER_HOUR=60
# Farmer news: RSS headline cache (ms). Default: 25 minutes
# FARMER_NEWS_RSS_CACHE_MS=1500000
# Farmer news: Groq snapshot cache (ms). Default: 45 minutes
# FARMER_NEWS_SNAPSHOT_MS=2700000

# Helmet: set to 1 only if a reverse proxy breaks debugging (CSP is API-oriented; see docs/SECURITY.md)
# HELMET_DISABLE_CSP=0

# Cloudinary (optional). When CLOUDINARY_CLOUD_NAME, API_KEY, and API_SECRET are set, listing images,
# avatars, and KYC uploads go to Cloudinary (HTTPS URLs) instead of local uploads/ — recommended on Render.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Optional folder prefix in Cloudinary (default: gaonbazaar)
# CLOUDINARY_FOLDER=gaonbazaar

# After multer saves a file, optional ClamAV scan (production). Requires clamdscan/clamd on the host.
# UPLOAD_VIRUS_SCAN=0
# UPLOAD_CLAMDSCAN_CMD=clamdscan
# UPLOAD_CLAMDSCAN_TIMEOUT_MS=60000
